generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ALUMNI
  ADMIN
}

model User {
  id              String       @id @default(cuid())
  nama            String
  email           String       @unique
  password        String
  emailVerified   DateTime?
  verifyToken     String?      @unique
  verifyExpires   DateTime?
  resetToken      String?      @unique
  resetExpires    DateTime?
  role            Role         @default(ALUMNI)
  alumni          Alumni?
  alumniImport    AlumniImport?
  submissions     Submission[]
  markomburTopics    MarkomburTopic[]
  markomburKomentar  MarkomburKomentar[]
  markomburReports   MarkomburReport[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([email])
  @@index([verifyToken])
}

model Alumni {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  namaLengkap  String
  tahunLulus   Int
  pekerjaan    String?
  alamat       String?
  noHp         String?
  foto         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tahunLulus])
  @@index([namaLengkap])
}

model Berita {
  id        String   @id @default(cuid())
  judul     String
  slug      String   @unique
  konten    String   @db.Text
  ringkasan String?
  gambar    String?
  penulis   String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([published, createdAt])
}

model Agenda {
  id        String   @id @default(cuid())
  judul     String
  deskripsi String   @db.Text
  tanggal   DateTime
  lokasi    String
  gambar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tanggal])
}

model Album {
  id         String   @id @default(cuid())
  judul      String
  deskripsi  String?
  coverImage String?
  fotos      Foto[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Foto {
  id        String   @id @default(cuid())
  albumId   String
  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  createdAt DateTime @default(now())
}

model SiteSettings {
  id                  String @id @default("default")
  namaOrganisasi      String @default("PASMADA")
  deskripsi           String @default("Parsadaan Alumni SMAN Sada - Organisasi Alumni SMAN 1 Panyabungan")
  sambutanKetua       String @default("") @db.Text
  heroImage           String?
  alamat              String @default("")
  email               String @default("")
  telepon             String @default("")
  facebook            String?
  instagram           String?
  youtube             String?
  // Halaman Tentang
  sejarah             String @default("") @db.Text
  visi                String @default("") @db.Text
  misi                String @default("") @db.Text
  strukturOrganisasi  String @default("[]") @db.Text
}

enum SubmissionType {
  BERITA
  AGENDA
  ALBUM
  SETTINGS
  ALUMNI_PILIHAN
  INFO
}

enum InfoKategori {
  LOKER
  USAHA
  AGEN
  LAINNYA
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model Submission {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      SubmissionType
  status    SubmissionStatus @default(PENDING)
  data      String           @db.Text
  adminNote String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([status])
  @@index([userId])
}

// Alumni imported from existing database (not yet registered)
model AlumniImport {
  id           String   @id @default(cuid())
  namaLengkap  String
  tahunLulus   Int
  noHp         String?
  pekerjaan    String?
  alamat       String?
  linkedUserId String?  @unique
  linkedUser   User?    @relation(fields: [linkedUserId], references: [id])
  createdAt    DateTime @default(now())

  @@index([tahunLulus])
  @@index([namaLengkap])
}

model AdminNotification {
  id        String   @id @default(cuid())
  type      String
  message   String   @db.Text
  data      String?  @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
}

// Info — lowongan kerja, promosi usaha alumni, agen, dll
model Info {
  id          String       @id @default(cuid())
  judul       String
  kategori    InfoKategori
  ringkasan   String       @db.Text
  konten      String       @db.Text
  gambar      String?
  kontak      String?
  link        String?
  expiredAt   DateTime?
  published   Boolean      @default(true)
  createdBy   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([published, kategori, createdAt])
  @@index([expiredAt])
}

// Profil Alumni Pilihan — kisah senior sukses untuk inspirasi
model AlumniPilihan {
  id           String   @id @default(cuid())
  nama         String
  tahunLulus   Int
  pekerjaan    String
  foto         String?
  ringkasan    String   @db.Text
  kisah        String   @db.Text
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([published, createdAt])
}

// Markombur — forum diskusi terbuka untuk alumni
model MarkomburTopic {
  id          String              @id @default(cuid())
  judul       String
  deskripsi   String              @db.Text
  authorId    String
  author      User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  komentar    MarkomburKomentar[]
  reports     MarkomburReport[]
  isLocked    Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([createdAt])
}

model MarkomburKomentar {
  id        String              @id @default(cuid())
  topicId   String
  topic     MarkomburTopic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  authorId  String
  author    User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  konten    String              @db.Text
  reports   MarkomburReport[]
  createdAt DateTime            @default(now())

  @@index([topicId, createdAt])
}

model MarkomburReport {
  id          String              @id @default(cuid())
  reporterId  String
  reporter    User                @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  topicId     String?
  topic       MarkomburTopic?     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  komentarId  String?
  komentar    MarkomburKomentar?  @relation(fields: [komentarId], references: [id], onDelete: Cascade)
  alasan      String              @db.Text
  resolved    Boolean             @default(false)
  createdAt   DateTime            @default(now())

  @@index([resolved, createdAt])
}
